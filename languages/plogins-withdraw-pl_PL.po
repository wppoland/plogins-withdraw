msgid "This order is no longer eligible for withdrawal."
msgstr "To zamówienie nie podlega już odstąpieniu."

#: src/Service/WithdrawalService.php:150
msgid "Please select at least one item to withdraw from."
msgstr ""
"Proszę wybrać przynajmniej jedną pozycję, z której chcesz się wycofać."

#: src/Service/WithdrawalService.php:196
msgid "This order is not in a status that can be withdrawn."
msgstr "To zamówienie nie ma statusu umożliwiającego odstąpienie."

#: src/Service/WithdrawalService.php:206
msgid "The withdrawal period for this order has ended."
msgstr "Okres odstąpienia od umowy dla tego zamówienia dobiegł końca."

#: src/Service/WithdrawalService.php:210
msgid "A withdrawal request for this order is already being processed."
msgstr "Wniosek o odstąpienie dla tego zamówienia jest już przetwarzany."

