#. Plugin Name of the plugin
#: plogins-withdraw.php
msgid "Plogins Withdraw - Right of Withdrawal Button for WooCommerce"
msgstr ""
"Plogins Withdraw - Przycisk prawa do odstąpienia od umowy dla WooCommerce"

#. Plugin URI of the plugin
#: plogins-withdraw.php
msgid "https://plogins.com/plogins-withdraw/"
msgstr "https://plogins.com/pl/plogins-withdraw/"

#. Description of the plugin
#: plogins-withdraw.php
msgid ""
"EU right-of-withdrawal button and form (Directive 2023/2673, Art. 11a): let "
"customers submit full or partial withdrawal requests for their orders, with "
"an admin log and email notifications."
msgstr ""
"Przycisk i formularz unijnego prawa do odstąpienia od umowy (Dyrektywa "
"2023/2673, art. 11a): umożliwiają klientom składanie wniosków o całkowite "
"lub częściowe odstąpienie od umowy dla swoich zamówień, z dziennikiem "
"administratora i powiadomieniami e-mail."

#. Author of the plugin
#: plogins-withdraw.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: plogins-withdraw.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

#: plogins-withdraw.php:56
msgid "Plogins Withdraw requires WooCommerce to be installed and active."
msgstr "Plogins Withdraw wymaga zainstalowanego i aktywnego WooCommerce."

