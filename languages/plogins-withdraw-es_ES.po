#. Plugin Name of the plugin
#: plogins-withdraw.php
msgid "Plogins Withdraw - Right of Withdrawal Button for WooCommerce"
msgstr ""
"Plogins Withdraw - Botón de derecho de desistimiento para WooCommerce"

#. Plugin URI of the plugin
#: plogins-withdraw.php
msgid "https://plogins.com/plogins-withdraw/"
msgstr "https://plogins.com/es/plogins-withdraw/"

#. Description of the plugin
#: plogins-withdraw.php
msgid ""
"EU right-of-withdrawal button and form (Directive 2023/2673, Art. 11a): let "
"customers submit full or partial withdrawal requests for their orders, with "
"an admin log and email notifications."
msgstr ""
"Botón y formulario de derecho de desistimiento de la UE (Directiva "
"2023/2673, Art. 11a): permite a los clientes enviar solicitudes de retiro "
"total o parcial de sus pedidos, con un registro de administrador y "
"notificaciones por correo electrónico."

#. Author of the plugin
#: plogins-withdraw.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: plogins-withdraw.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

#: plogins-withdraw.php:56
msgid "Plogins Withdraw requires WooCommerce to be installed and active."
msgstr "Plogins Withdraw requiere que WooCommerce esté instalado y activo."

#: src/Admin/RequestsAdmin.php:35 src/Admin/RequestsAdmin.php:36
#: src/Admin/RequestsAdmin.php:71
msgid "Withdrawal Requests"
msgstr "Solicitudes de desistimiento"

