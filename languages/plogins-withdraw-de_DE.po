#. Plugin Name of the plugin
#: plogins-withdraw.php
msgid "Plogins Withdraw - Right of Withdrawal Button for WooCommerce"
msgstr "Plogins Withdraw – Widerrufsrecht-Button für WooCommerce"

#. Plugin URI of the plugin
#: plogins-withdraw.php
msgid "https://plogins.com/plogins-withdraw/"
msgstr "https://plogins.com/de/plogins-withdraw/"

#. Description of the plugin
#: plogins-withdraw.php
msgid ""
"EU right-of-withdrawal button and form (Directive 2023/2673, Art. 11a): let "
"customers submit full or partial withdrawal requests for their orders, with "
"an admin log and email notifications."
msgstr ""
"Schaltfläche und Formular zum EU-Widerrufsrecht (Richtlinie 2023/2673, Art. "
"11a): Ermögliche Kunden, vollständige oder teilweise Widerrufsanfragen für "
"ihre Bestellungen einzureichen, mit einem Administratorprotokoll und E-Mail-"
"Benachrichtigungen."

#. Author of the plugin
#: plogins-withdraw.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: plogins-withdraw.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

#: plogins-withdraw.php:56
msgid "Plogins Withdraw requires WooCommerce to be installed and active."
msgstr "Für Plogins Withdraw muss WooCommerce installiert und aktiv sein."

